{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saripalana.github.io/ks-study-guide/schemas/question-bank.schema.json",
  "title": "ABPN Personal Study Question Bank Package",
  "type": "object",
  "required": ["schemaVersion", "platformId", "projectId", "datasetId", "bankId", "questionCount", "bankHash", "questions"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "platformId": { "const": "abpn-personal-study-platform" },
    "projectId": { "const": "psychiatry-board-practice" },
    "datasetId": { "type": "string", "minLength": 1 },
    "bankId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "environment": { "type": "string" },
    "questionCount": { "type": "integer", "minimum": 1, "maximum": 5000 },
    "bankHash": { "type": "string", "minLength": 1 },
    "bank": {
      "type": "object",
      "properties": {
        "bankId": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "boardExam": { "type": "string" },
        "personalUseOnly": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5000,
      "items": {
        "type": "object",
        "required": ["bankId", "id", "compositeId", "chapter", "chapterTitle", "qnum", "question", "choices", "choiceLetters", "correctLetter", "answerText", "explanation"],
        "properties": {
          "bankId": { "type": "string", "minLength": 1 },
          "id": { "type": "string", "minLength": 1 },
          "compositeId": { "type": "string", "pattern": "^[^:]+::.+$" },
          "contentVersion": { "type": "integer", "minimum": 1 },
          "status": { "type": "string" },
          "cardType": { "type": "string" },
          "chapter": { "type": "integer", "minimum": 1 },
          "chapterTitle": { "type": "string" },
          "qnum": { "type": "integer", "minimum": 1 },
          "question": { "type": "string", "minLength": 1 },
          "choices": { "type": "array", "minItems": 2, "items": { "type": "string" } },
          "choiceLetters": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 } },
          "correctLetter": { "type": "string", "minLength": 1 },
          "answerText": { "type": "string" },
          "explanation": { "type": "string" },
          "categories": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "label", "type"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "label": { "type": "string", "minLength": 1 },
                "type": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "categoryIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "difficulty": { "type": ["string", "null"] },
          "learningObjectives": { "type": "array", "items": { "type": "string" } },
          "source": { "type": ["object", "null"] },
          "references": { "type": "array" },
          "createdAt": {},
          "updatedAt": {}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
